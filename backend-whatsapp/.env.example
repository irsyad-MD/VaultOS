# Server
PORT=3001

# Supabase (gunakan SERVICE ROLE KEY, bukan anon key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Groq AI (dapatkan di console.groq.com)
GROQ_API_KEY=your-groq-api-key-here

# Session folder
SESSION_DIR=./sessions

# Secret key untuk proteksi API endpoint
API_SECRET=ganti-dengan-random-string-panjang
